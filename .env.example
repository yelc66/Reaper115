# Copy this file to .env before running docker compose.
# All paths are host paths. Create them before starting the service.

TZ=Asia/Shanghai
BOT_IMAGE=qiqiandfei/115-bot:latest

# Persistent bot config, database, 115 tokens, and optional Telegram session.
CONFIG_DIR=./config

# Temporary files used by the bot.
TMP_DIR=./tmp

# Host directory mapped to /media. config.yaml defaults strm_root to /media/115.
MEDIA_DIR=./media

# Host directory mapped to /CloudNAS. Required only when strm_mode is strm_local
# or when your config.yaml mount_root points to /CloudNAS/115.
CLOUDNAS_DIR=./CloudNAS

# Optional network/proxy settings. Local development scripts also load these.
# FLARESOLVERR_URL=http://flaresolverr:8191/v1
# REMOTE_SELENIUM_URL=http://chrome:4444/wd/hub
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1,::1,chrome,flaresolverr
