# Telegram-115Bot配置文件, 请检查所有必填项目，如不填会影响机器人正常运行

############################################日志设置##################################
# log_level （必填）
# 日志级别
# debug|info|warning|error|critical
log_level: info
############################################Web管理界面##################################
web:
  # 是否启动 FastAPI Web API
  enable: true
  # 容器内监听地址，Docker 部署保持 0.0.0.0
  host: 0.0.0.0
  # 容器内监听端口；docker-compose 默认映射到宿主机 WEB_PORT 或 8000
  port: 8000
############################################Telegram设置##################################
# bot token （必填）
# 机器人唯一Token，如果没有@BotFather创建
bot_token: your_bot_token

# allowed_user （必填）
# 授权可以使用该bot的user_id，可以通过@getidsbot获取
# 数字类型不要引号
allowed_user: your_user_id

# 机器人名称 例如：@your_bot_name 
# 非必填，转存视频需要
bot_name: "@your_bot_name"

# telegram 的api信息 
# 非必填，转存视频需要
tg_api_id: your_tg_api_id
tg_api_hash: your_tg_api_hash

############################################115开放平台##################################
# 115_app_id 
# 申请地址https://open.115.com/
# 如已填写115_app_id, access_token,refresh_token可留空！
115_app_id: your_115_app_id

# 如没有115_app_id，请填写access_token和refresh_token！
# 115_app_id和token不能同时为空！！！
access_token: your_access_token
refresh_token: your_refresh_token

#############################################115离线下载设置###################################
# 下载完成后自动删除文件夹中的广告文件
clean_policy:
  # 是否开启自动清理 on: 开启 off: 关闭
  # 当设置为off时，所有策略不会生效，默认为开启
  switch: "on"
  # 文件小于设置值则自动删除单位K,M,G
  less_than: 400M
#############################################涩花Spider##################################
# 每天凌晨开启爬虫，爬取前一天的数据并离线到115
sehuatang_spider:
  # 是否开启涩花爬虫
  enable: false
  # 指定每天的同步时间(24h)建议设置为03:00
  # 默认同步前一天的数据，建议3点开更，避开凌晨高峰
  # 如频繁触发CF盾，建议将时间改成白天，白天成功率高
  sync_time: "03:00"
  # BaseUrl
  # 涩花地址，建议填临时地址，速度快~
  # 留空默认永久地址 www.sehuatang.net; www.sehuatang.org
  base_url: www.sehuatang.net
  # 涩花 Cookie，可从浏览器开发者工具复制 Cookie 请求头，格式: a=b; c=d
  # 建议只填当前 base_url 域名下的 Cookie，留空则不注入
  cookie_string: ""
  # 也支持结构化 Cookie；与 cookie_string 可同时使用
  # cookies:
  #   - name: example_name
  #     value: example_value
  #     domain: .sehuatang.net
  #     path: /
  # 支持爬取版块["国产原创", "亚洲无码原创", "亚洲有码原创", "高清中文字幕", "素人有码系列","4K原版","VR视频区","欧美无码"]
  # 至少填一个
  sections:
    - name: 国产原创
      save_path: /AV/涩花/国产原创
#    - name: 亚洲无码原创
#      save_path: /AV/涩花/亚洲无码原创
#    - name: 亚洲有码原创
#      save_path: /AV/涩花/亚洲有码原创
#    - name: 高清中文字幕
#      save_path: /AV/涩花/高清中文字幕
#    - name: 素人有码系列
#      save_path: /AV/涩花/素人有码
#    - name: 4K原版
#      save_path: /AV/涩花/4K原版
#    - name: VR视频区
#      save_path: /AV/涩花/VR视频区
#    - name: 欧美无码
#      save_path: /AV/涩花/欧美无码
  # 通知我
  notify_me: true
  # 按年月整理，开启后会自动在保存目录创建年/月的文件夹
  sort_by_year_month: false
  

# 订阅条件，全部满足才订阅
sub_condition:
  # 包含中字
  zh_cn: true
  # Dolby Vision
  dolby_vision: false
  # 分辨率优先级
  resolution_priority:
    - 2160
    - 1080

  ##########################################AI#######################################
# AI支持
ai:
  # 请求地址
  api_url: https://api.siliconflow.cn/v1
  # api_key
  api_key: sk-xxxxxxxxxxxxxxxxxxx
  # 模型
  model: deepseek-ai/DeepSeek-V3.2



