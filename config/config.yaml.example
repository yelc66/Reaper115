# Reaper115 配置模板
# 复制为 config/config.yaml 后填入自己的密钥和路径。

log_level: info

############################################Telegram##################################
bot_token: ""
allowed_user: ""

############################################115 开放平台##################################
# 填写 app_id 后可通过 Web UI 扫码授权
115_app_id: ""
access_token: ""
refresh_token: ""

############################################涩花爬虫##################################
sehuatang_spider:
  enable: false
  sync_time: "03:00"
  base_url: www.sehuatang.net
  cookie_string: ""
  # 远程 Selenium host（留空则不使用，/wd/hub 由代码自动拼接）
  remote_selenium_url: ""
  # FlareSolverr host（留空则不使用，/v1 由代码自动拼接）
  flaresolverr_url: ""
  sections:
    - name: 高清中文字幕
      save_path: /AV/涩花/高清中文字幕
      rules: []
      # rules 示例（留空表示该板块所有标题都下载）:
      # rules:
      #   - name: 无码字幕
      #     pattern: 无码字幕
      #     save_path: /AV/涩花/无码字幕   # 可选，覆盖板块路径
      #     kind: include   # include=包含 / exclude=排除
      #     active: true
  notify_me: true
  notify_with_image: false
  sort_by_year_month: false
  rename_by_title: true

############################################AI##################################
ai:
  api_url: https://api.siliconflow.cn/v1
  api_key: ""
  model: deepseek-ai/DeepSeek-V3.2

############################################Web 管理界面##################################
web:
  enable: true
  port: 8000
  auth_key: ""

############################################广告清理##################################
clean_policy:
  switch: "on"
  less_than: 400M
